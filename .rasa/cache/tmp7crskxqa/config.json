{
  "prompt_template": null,
  "user_input": null,
  "llm": {
    "id": "gemini_llm",
    "models": [
      {
        "provider": "gemini",
        "model": "gemini-1.5-flash",
        "api_key": "${GEMINI_API_KEY}"
      }
    ]
  },
  "flow_retrieval": {
    "embeddings": {
      "id": "huggingface_embedding_model",
      "models": [
        {
          "provider": "huggingface",
          "model": "BAAI/bge-small-en-v1.5",
          "model_kwargs": {
            "device": "cpu"
          },
          "encode_kwargs": {
            "normalize_embeddings": true
          }
        }
      ]
    },
    "num_flows": 20,
    "turns_to_embed": 1,
    "should_embed_slots": true
  }
}